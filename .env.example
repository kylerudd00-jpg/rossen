# Required — AI headline generation and story filtering
GROQ_API_KEY=

# ── Image search (pick ONE — both are free) ───────────────────────────────────

# OPTION A: Brave Search API — easiest setup, one key, 2000 free queries/month
# Sign up at: https://api.search.brave.com  (no credit card required)
BRAVE_API_KEY=

# OPTION B: Google Custom Search — 100 free queries/day, two keys needed
# 1. console.cloud.google.com → create project → enable "Custom Search API" → create API key
# 2. programmablesearchengine.google.com → create engine → enable "Search entire web" + "Image search" → copy cx ID
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
