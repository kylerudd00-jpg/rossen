# ── AI (required for headline generation and agentic search) ──────────────────
# Groq is free and used as the fallback AI provider.
GROQ_API_KEY=

# Gemini is the primary story research provider. Uses Google Search grounding
# to find, verify, and write story cards in one pass — free tier is sufficient.
# Sign up at: aistudio.google.com
GEMINI_API_KEY=
# GEMINI_RESEARCH_MODEL=gemini-2.0-flash   # override if you want a newer model
# GEMINI_STORY_COUNT=12
# GEMINI_RESEARCH_TIMEOUT_MS=90000

# OpenAI is the preferred story research provider. It uses Responses API web
# search to find, verify, and write story cards in one pass.
OPENAI_API_KEY=
OPENAI_RESEARCH_MODEL=gpt-5.5
OPENAI_HEADLINE_MODEL=gpt-5.4-mini
OPENAI_STORY_COUNT=12
OPENAI_REASONING_EFFORT=medium

# ── Search APIs (used by the agentic search loop) ────────────────────────────
# The agent alternates between available backends to spread quota load.
# Falls back to Google News RSS if neither key is set (free, less detailed).

# Brave Search — 2,000 free queries/month, $5/1,000 after
# Sign up at: https://api.search.brave.com  (no credit card required)
BRAVE_API_KEY=

# Tavily — 1,000 free queries/month, built for AI agents, returns full summaries
# Sign up at: https://tavily.com
TAVILY_API_KEY=

# ── Image search ──────────────────────────────────────────────────────────────
# OPTION A: Google Custom Search — 100 free queries/day
# 1. console.cloud.google.com → create project → enable "Custom Search API" → create API key
# 2. programmablesearchengine.google.com → create engine → enable "Search entire web" + "Image search" → copy cx ID
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# ── Tuning ────────────────────────────────────────────────────────────────────
# AGENT_MAX_ROUNDS: how many search rounds the AI agent runs per fetch.
# Each round may execute multiple parallel searches. Default: 20.
# Increase for more coverage; decrease to save Brave API quota.
AGENT_MAX_ROUNDS=20
PREFILTER_LIMIT=120
BRAND_STORY_LIMIT=3
AI_CANDIDATE_LIMIT=80
